{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Postgres": ""
  },
  "RabbitMq": {
    "Host": "localhost",
    "Port": 5672,
    "Username": "",
    "Password": ""
  },
  "Minio": {
    "Endpoint": "http://localhost:9000",
    "ClusterEndpoint": "http://host.k3d.internal:9000",
    "AccessKey": "",
    "SecretKey": "",
    "Bucket": "eaap"
  },
  "Opa": {
    "BaseUrl": "http://localhost:8181",
    "PolicyName": "quality-gate/default",
    "MaxWarnings": 100
  },
  "Argo": {
    "BaseUrl": "http://localhost:2746",
    "Namespace": "argo",
    "Token": "",
    "PollIntervalSeconds": 5
  },
  "Adapters": {
    "megalinter": {
      "Image": "eaap/adapter-megalinter:latest",
      "TimeoutSeconds": 1800,
      "Category": "lint"
    },
    "test-report": {
      "Image": "eaap/adapter-test-report:latest",
      "TimeoutSeconds": 300,
      "Category": "test"
    },
    "coverage": {
      "Image": "eaap/adapter-coverage:latest",
      "TimeoutSeconds": 300,
      "Category": "coverage"
    },
    "trivy": {
      "Image": "eaap/adapter-trivy:latest",
      "TimeoutSeconds": 900,
      "Category": "security"
    },
    "semgrep": {
      "Image": "eaap/adapter-semgrep:latest",
      "TimeoutSeconds": 900,
      "Category": "security"
    },
    "gitleaks": {
      "Image": "eaap/adapter-gitleaks:latest",
      "TimeoutSeconds": 600,
      "Category": "security"
    }
  }
}
