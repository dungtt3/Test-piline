# ---- Test / coverage results ----
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
# NB: avoid a bare "*.coverage" — on case-insensitive filesystems it also matches
# the src/Eaap.Adapters.Coverage directory and would ignore its whole source tree.
/coverage*.json
/coverage*.xml
/coverage*.info
TestResults/

# ---- NuGet ----
*.nupkg
*.snupkg
**/packages/*
!**/packages/build/
.nuget/

